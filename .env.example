# ============================================================
# PhimVerse — environment variables
# Copy to .env.local for local dev. On Vercel, set these in
# Project Settings → Environment Variables (or `vercel env add`).
# Every variable is OPTIONAL for local demo mode — the app boots
# with an in-memory catalog when DATABASE_URL is missing.
# ============================================================

# --- Auth (required in production) ---
# Generate: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=

# --- Relational DB: Neon Postgres (Vercel Marketplace) ---
# Auto-injected when you connect Neon via the Vercel Marketplace.
DATABASE_URL=

# --- NoSQL: Upstash Redis (Vercel Marketplace) ---
# Auto-injected as UPSTASH_* (or KV_* on some setups — both are supported).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Vercel Blob (fast object storage for posters/backdrops) ---
# Auto-injected when you create a Blob store in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# --- OneDrive streaming (Microsoft Graph) ---
# Mode A: Personal OneDrive (consumer account) — delegated refresh token
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=

# Mode B: OneDrive for Business — app-only client credentials
# (set MS_TENANT_ID + MS_CLIENT_SECRET, leave MS_REFRESH_TOKEN empty)
MS_TENANT_ID=
# Target a specific drive (required for Mode B, optional for Mode A):
ONEDRIVE_DRIVE_ID=

# --- Policies ---
# 1 = only signed-in users can stream (recommended in production)
STREAM_REQUIRE_AUTH=
# Comma-separated emails allowed to use POST /api/upload
ADMIN_EMAILS=
